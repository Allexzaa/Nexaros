# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/aischeduler

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Bootstrap (production first-time setup) ───────────────────────────────────
BOOTSTRAP_SECRET=replace-with-a-long-random-secret

# ── Dev seed script (disabled in NODE_ENV=production) ────────────────────────
SEED_BUSINESS_NAME=Test Office
SEED_ADMIN_EMAIL=admin@test.com
SEED_ADMIN_PASSWORD=changeme

# ── AI Engine ─────────────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3

# ── Email (First Contact Bootstrap) ──────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxx
APP_DOMAIN=app.myscheduler.com

# ── Push Notifications ────────────────────────────────────────────────────────
# Paste the full Firebase service account JSON as a single line
FIREBASE_SERVICE_ACCOUNT={}

# ── Google SSO ────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxx

# ── Job Scheduler ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
BULL_CONCURRENCY=10
